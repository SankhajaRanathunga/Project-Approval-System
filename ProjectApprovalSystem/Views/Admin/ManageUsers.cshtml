@model IEnumerable<ProjectApprovalSystem.Models.ApplicationUser>

@{
    ViewData["Title"] = "User Management";
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h1 class="h3 fw-bold">User Management</h1>
        <p class="text-muted">Manage roles and profiles for Students and Supervisors.</p>
    </div>
    <div class="col-auto">
        <a asp-action="CreateUser" class="btn btn-primary fw-bold px-4">
            <i class="bi bi-person-plus-fill me-2"></i>Create New User
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3">User</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Joined</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                        <i class="bi bi-person text-secondary"></i>
                                    </div>
                                    <div class="fw-bold">@user.FullName</div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <!-- Simplified for exercise; in real app we'd fetch actual roles -->
                                <span class="badge bg-info">User Account</span>
                            </td>
                            <td>@DateTime.Now.ToShortDateString()</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-secondary">Edit</button>
                                <button class="btn btn-sm btn-outline-danger ms-1">Deactivate</button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-people display-4 d-block mb-3 opacity-25"></i>
                                No users found in the system.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
