@model IEnumerable<ProjectApprovalSystem.Models.ProjectProposal>
@using ProjectApprovalSystem.Models.Enums

@{
    ViewData["Title"] = "Admin Oversight Panel";
}

<div class="row g-4 mb-5">
    <div class="col-md-12">
        <h1 class="display-5 fw-bold mb-0 text-dark">Administrative Oversight</h1>
        <p class="lead text-muted">Manage the entire matching lifecycle across all research areas.</p>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-primary text-white h-100 p-3 rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Total Proposals</h6>
                        <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalProposals</h2>
                    </div>
                    <i class="bi bi-file-earmark-text display-4 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-success text-white h-100 p-3 rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Total Matches</h6>
                        <h2 class="display-4 fw-bold mb-0">@ViewBag.MatchedProposals</h2>
                    </div>
                    <i class="bi bi-check-circle display-4 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-warning text-dark h-100 p-3 rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Pending Reviews</h6>
                        <h2 class="display-4 fw-bold mb-0">@ViewBag.PendingProposals</h2>
                    </div>
                    <i class="bi bi-clock-history display-4 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
    <div class="card-header bg-white py-4 px-5 border-0 d-flex justify-content-between align-items-center">
        <div>
            <h4 class="fw-bold mb-0">Proposal Management Queue</h4>
            <p class="text-muted small mb-0">Full visibility into all coursework project submissions</p>
        </div>
        <div class="btn-group shadow-sm">
            <a asp-action="ManageResearchAreas" class="btn btn-outline-dark px-4 py-2 fw-bold small"><i class="bi bi-tags me-2"></i>Research Areas</a>
            <a asp-action="ManageUsers" class="btn btn-outline-dark px-4 py-2 fw-bold small"><i class="bi bi-people me-2"></i>Users</a>
            <a asp-action="MatchOversight" class="btn btn-primary px-4 py-2 fw-bold small"><i class="bi bi-eye me-2"></i>View All Matches</a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom border-top">
                    <tr>
                        <th class="ps-5 py-3">Project Title</th>
                        <th>Student / Identity</th>
                        <th>Domain Area</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th class="pe-5 text-end">Administration</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-5 py-3">
                                <div class="fw-bold text-dark fs-6">@item.Title</div>
                                <div class="text-muted tiny">#ID-@item.Id</div>
                            </td>
                            <td>
                                <div class="fw-bold">@(item.Student?.User?.FullName ?? "N/A")</div>
                                <div class="tiny text-primary">@item.Student?.StudentId</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-2 py-1">@item.ResearchArea?.Name</span>
                            </td>
                            <td>
                                <span class="badge @GetBadgeClass(item.Status) px-3 py-2 rounded-pill">@item.Status</span>
                            </td>
                            <td>@item.SubmittedAt.ToString("MMM dd")</td>
                            <td class="pe-5 text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light border-0 rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                                        <li><a class="dropdown-item py-2" asp-action="Details" asp-controller="Student" asp-route-id="@item.Id"><i class="bi bi-eye me-2"></i>View Proposal</a></li>
                                        @if (item.IsMatched)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="CancelMatch" asp-route-proposalId="@item.Id" method="post" onsubmit="return confirm('WARNING: Breaking this match will rollback the matching status for both users. Proceed?')">
                                                    <button type="submit" class="dropdown-item text-danger py-2"><i class="bi bi-x-circle me-2"></i>Cancel Match</button>
                                                </form>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    string GetBadgeClass(ProjectStatus status) => status switch
    {
        ProjectStatus.Pending => "bg-warning text-dark",
        ProjectStatus.UnderReview => "bg-info text-white",
        ProjectStatus.Matched => "bg-success text-white",
        ProjectStatus.Withdrawn => "bg-secondary text-white",
        _ => "bg-dark text-white"
    };
}

<style>
    .tiny { font-size: 0.75rem; }
    .table-hover tbody tr:hover { background-color: rgba(63, 81, 181, 0.02); }
</style>
