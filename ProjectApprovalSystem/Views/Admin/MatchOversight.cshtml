@model IEnumerable<ProjectApprovalSystem.ViewModels.MatchDetailsViewModel>

@{
    ViewData["Title"] = "Match Oversight";
}

<div class="row mb-5">
    <div class="col-md-12">
        <div class="d-flex align-items-center mb-3">
            <div class="bg-indigo p-3 rounded-4 shadow-sm me-3">
                <i class="bi bi-person-check-fill text-white fs-2"></i>
            </div>
            <div>
                <h1 class="display-6 fw-bold mb-0">Match Oversight</h1>
                <p class="text-muted lead mb-0">Monitor and manage all established student-supervisor pairs.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
                <div class="card-header bg-indigo text-white py-3 px-4 d-flex justify-content-between align-items-center">
                    <span class="small fw-bold text-uppercase tracking-wider">Match ID: #@item.ProposalId</span>
                    <span class="badge bg-success px-3 rounded-pill">CONFIRMED</span>
                </div>
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">@item.Title</h5>
                    
                    <div class="row g-3">
                        <div class="col-6 border-end">
                            <label class="text-muted tiny fw-bold text-uppercase d-block mb-1">Student</label>
                            <div class="fw-bold text-dark">@item.StudentFullName</div>
                            <div class="small text-muted">@item.StudentId</div>
                        </div>
                        <div class="col-6 ps-3">
                            <label class="text-muted tiny fw-bold text-uppercase d-block mb-1">Supervisor</label>
                            <div class="fw-bold text-primary">@item.SupervisorFullName</div>
                            <div class="small text-muted">@item.SupervisorStaffId</div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light border-0 p-3 d-flex justify-content-between">
                    <div class="small text-muted mt-1">Matched: @item.MatchedAt.ToString("MMM dd, yyyy")</div>
                    <div class="d-flex gap-2">
                        <form asp-action="CancelMatch" asp-route-proposalId="@item.ProposalId" method="post" onsubmit="return confirm('Cancel this match and reset proposal status?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-pill fw-bold">
                                <i class="bi bi-x-circle me-1"></i>Cancel Match
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="bg-white p-5 rounded-4 shadow-sm border">
                <i class="bi bi-clipboard-x display-1 text-muted opacity-25"></i>
                <h4 class="mt-3 fw-bold">No active matches recorded</h4>
                <p class="text-muted">Wait for supervisors to confirm project proposals.</p>
            </div>
        </div>
    }
</div>

<style>
    .bg-indigo { background-color: #3f51b5; }
    .tiny { font-size: 0.7rem; }
    .tracking-wider { letter-spacing: 0.1em; }
</style>
