@model IEnumerable<ProjectApprovalSystem.Models.ProjectProposal>
@using ProjectApprovalSystem.Models.Enums

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="row mb-5">
    <div class="col-md-8">
        <h1 class="display-5 fw-bold mb-0">My Proposals</h1>
        <p class="lead text-muted">Submit, track, and manage your project ideas for blind matching.</p>
    </div>
    <div class="col-md-4 text-md-end d-flex align-items-center justify-content-md-end">
        <a asp-action="CreateProposal" class="btn btn-primary btn-lg px-4 shadow rounded-pill">
            <i class="bi bi-plus-lg me-2"></i>Submit New Proposal
        </a>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm hover-up border-0">
                <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between">
                    <span class="badge @GetStatusClass(item.Status) px-3 py-2 rounded-pill">@item.Status</span>
                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>@item.SubmittedAt.ToString("MMM dd")</small>
                </div>
                <div class="card-body px-4 pb-4">
                    <h5 class="card-title fw-bold mb-3 mt-2" style="font-size: 1.25rem;">@item.Title</h5>
                    <p class="card-text text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">@item.Abstract</p>
                    
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (!string.IsNullOrEmpty(item.TechnicalStack))
                        {
                            @foreach (var tech in item.TechnicalStack.Split(','))
                            {
                                <span class="badge bg-light text-primary border px-2 py-1">@tech.Trim()</span>
                            }
                        }
                    </div>
                    
                    @if (item.IsMatched)
                    {
                        <div class="alert alert-success d-flex align-items-center py-2 px-3 border-0 rounded-3 mb-0">
                            <i class="bi bi-person-check-fill me-2 fs-5"></i>
                            <div>Match Confirmed! Review details.</div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-light border-0 px-4 py-3 d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark px-3 py-2 rounded-3 fw-bold">
                        <i class="bi bi-info-circle me-1"></i>Details
                    </a>
                    
                    <div class="d-flex gap-2">
                        @if (!item.IsMatched && item.Status != ProjectStatus.Withdrawn)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border px-3 py-2 rounded-3">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <form asp-action="Withdraw" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to withdraw this proposal?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger px-3 py-2 rounded-3">
                                    <i class="bi bi-trash me-1"></i>Withdraw
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
                <i class="bi bi-folder-plus display-1 text-primary opacity-25"></i>
                <h3 class="mt-4 fw-bold">No active proposals</h3>
                <p class="text-muted mb-4">Start your journey by submitting your first project proposal for supervisor review.</p>
                <a asp-action="CreateProposal" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">Submit Your First Proposal</a>
            </div>
        </div>
    }
</div>

@functions {
    string GetStatusClass(ProjectStatus status) => status switch
    {
        ProjectStatus.Pending => "bg-warning text-dark",
        ProjectStatus.UnderReview => "bg-info text-white",
        ProjectStatus.Matched => "bg-success text-white",
        ProjectStatus.Withdrawn => "bg-secondary text-white",
        _ => "bg-dark text-white"
    };
}

<style>
    .hover-up { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .hover-up:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.08) !important; }
    .card-text {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
