@model ProjectApprovalSystem.Models.ProjectProposal
@using ProjectApprovalSystem.Models.Enums

@{
    ViewData["Title"] = "Proposal Details";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i>Back to My Dashboard
            </a>
            <div>
                @if (!Model.IsMatched && Model.Status != ProjectStatus.Withdrawn)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 me-2">
                        <i class="bi bi-pencil me-1"></i>Edit Proposal
                    </a>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
            <div class="card-body p-5">
                <div class="row">
                    <div class="col-lg-8">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge @GetStatusClass(Model.Status) px-3 py-2 rounded-pill me-3">@Model.Status</span>
                            <span class="text-muted"><i class="bi bi-calendar-event me-1"></i>Submitted on @Model.SubmittedAt.ToString("MMMM dd, yyyy")</span>
                        </div>
                        <h1 class="fw-bold mb-4 text-dark">@Model.Title</h1>
                        
                        <div class="mb-5">
                            <h5 class="fw-bold text-uppercase small text-muted mb-3">Abstract</h5>
                            <p class="lead" style="line-height: 1.8; text-align: justify;">@Model.Abstract</p>
                        </div>
                        
                        <div class="mb-4">
                            <h5 class="fw-bold text-uppercase small text-muted mb-3">Technical Stack</h5>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrEmpty(Model.TechnicalStack))
                                {
                                    @foreach (var tech in Model.TechnicalStack.Split(','))
                                    {
                                        <span class="badge bg-light text-primary border px-3 py-2 fs-6">@tech.Trim()</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-lg-4">
                        <div class="bg-light p-4 rounded-4 h-100">
                            <h5 class="fw-bold mb-4"><i class="bi bi-info-square-fill me-2 text-primary"></i>Status & Matching</h5>
                            
                            <div class="mb-4 pb-3 border-bottom">
                                <label class="text-muted small fw-bold text-uppercase d-block mb-1">Research Area</label>
                                <div class="fw-bold">@Model.ResearchArea?.Name</div>
                            </div>

                            @if (Model.IsMatched)
                            {
                                <div class="text-center py-4">
                                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                                        <i class="bi bi-check-all text-success fs-1"></i>
                                    </div>
                                    <h4 class="fw-bold text-success mb-2">Matched!</h4>
                                    <p class="small text-muted mb-4">The identity reveal has occurred. Your assigned supervisor's details are below.</p>
                                    
                                    <div class="text-start bg-white p-3 rounded-3 shadow-sm">
                                        <div class="mb-2">
                                            <label class="text-muted tiny text-uppercase fw-bold d-block">Supervisor</label>
                                            <div class="fw-bold text-primary">Dr. Placeholder (Identity Revealed)</div>
                                        </div>
                                        <div>
                                            <label class="text-muted tiny text-uppercase fw-bold d-block">Match Date</label>
                                            <div class="small">@Model.MatchedAt?.ToString("MMM dd, yyyy")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <div class="spinner-border text-primary mb-3" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <h5 class="fw-bold mt-2">Waiting for Match</h5>
                                    <p class="small text-muted">Supervisors are currently reviewing proposals anonymously.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusClass(ProjectStatus status) => status switch
    {
        ProjectStatus.Pending => "bg-warning text-dark",
        ProjectStatus.UnderReview => "bg-info text-white",
        ProjectStatus.Matched => "bg-success text-white",
        ProjectStatus.Withdrawn => "bg-secondary text-white",
        _ => "bg-dark text-white"
    };
}

<style>
    .tiny { font-size: 0.65rem; letter-spacing: 0.05em; }
</style>
