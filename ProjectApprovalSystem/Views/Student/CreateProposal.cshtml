@model ProjectApprovalSystem.Models.ProjectProposal

@{
    ViewData["Title"] = "Submit New Proposal";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-primary py-4 px-5 border-0 text-white">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 me-3">
                        <i class="bi bi-file-earmark-plus fs-3"></i>
                    </div>
                    <div>
                        <h2 class="h4 fw-bold mb-0">Project Submission</h2>
                        <p class="mb-0 opacity-75 small text-uppercase fw-semibold">Coursework 2026 Process</p>
                    </div>
                </div>
            </div>
            <div class="card-body p-5">
                <form asp-action="CreateProposal" id="proposalForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 shadow-sm mb-4" role="alert"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold text-dark">Propject Title</label>
                        <input asp-for="Title" class="form-control form-control-lg border-2" placeholder="e.g., Blockchain for Supply Chain Transparency" />
                        <span asp-validation-for="Title" class="text-danger small fw-medium"></span>
                        <div class="form-text mt-2">Make it descriptive and clear for supervisors.</div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label asp-for="ResearchAreaId" class="form-label fw-bold text-dark">Research Area / Domain</label>
                            <select asp-for="ResearchAreaId" class="form-select form-select-lg border-2" asp-items="@(new SelectList(ViewBag.ResearchAreas, "Id", "Name"))">
                                <option value="">-- Choose closest match --</option>
                            </select>
                            <span asp-validation-for="ResearchAreaId" class="text-danger small fw-medium"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Abstract" class="form-label fw-bold text-dark">Project Abstract / Summary</label>
                        <textarea asp-for="Abstract" class="form-control border-2" rows="6" placeholder="Describe the core problem, objectives, and proposed solution..."></textarea>
                        <span asp-validation-for="Abstract" class="text-danger small fw-medium"></span>
                        <div class="form-text d-flex justify-content-between mt-2">
                             <span>Be detailed for better matching probability.</span>
                             <span id="charCount" class="text-muted">0 / 1000</span>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label asp-for="TechnicalStack" class="form-label fw-bold text-dark">Recommended Tech Stack</label>
                        <input asp-for="TechnicalStack" class="form-control border-2" placeholder="e.g., .NET 8, React, SQL Server, Python, Azure" />
                        <span asp-validation-for="TechnicalStack" class="text-danger small fw-medium"></span>
                        <div class="form-text mt-2">Comma separated list of technologies you intend to use.</div>
                    </div>

                    <div class="d-flex gap-3 pt-3">
                        <a asp-action="Dashboard" class="btn btn-light btn-lg flex-grow-1 border px-4 py-3 rounded-3 text-muted">
                            <i class="bi bi-x-lg me-2"></i>Discard
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1 px-4 py-3 rounded-3 shadow">
                            <i class="bi bi-send-fill me-2"></i>Submit for Review
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            $('textarea').on('input', function() {
                $('#charCount').text(this.value.length + " / 1000");
            });
        });
    </script>
}
