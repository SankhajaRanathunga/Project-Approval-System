@using Microsoft.AspNetCore.Identity
@using ProjectApprovalSystem.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    <li class="nav-item">
        <a class="nav-link px-3" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="bi bi-person-circle me-1"></i>@(user?.FullName ?? User.Identity?.Name)
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link px-3 border-0"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link px-3" asp-area="Identity" asp-page="/Account/Register"><i class="bi bi-person-plus me-1"></i>Register</a>
    </li>
    <li class="nav-item ms-lg-2">
        <a class="nav-link px-4 btn btn-outline-light rounded-pill" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
