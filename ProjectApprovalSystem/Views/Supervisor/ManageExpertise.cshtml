@model ProjectApprovalSystem.Models.SupervisorProfile

@{
    ViewData["Title"] = "Manage Research Areas";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="row mb-5">
            <div class="col-md-12">
                <h1 class="display-5 fw-bold mb-0">Expertise Profile</h1>
                <p class="lead text-muted">Selecting your research areas automatically highlights relevant student proposals on your dashboard.</p>
            </div>
        </div>

        <div class="card shadow border-0 rounded-4 overflow-hidden mb-5">
            <div class="card-header bg-dark text-white py-3 px-4">
                <span class="fw-bold fw-monospace text-uppercase small tracking-widest"><i class="bi bi-gear-fill me-2"></i>Discovery Preferences</span>
            </div>
            <div class="card-body p-5">
                <form asp-action="ManageExpertise" method="post">
                    <div class="row g-4 mb-5">
                        @foreach (var area in (IEnumerable<ProjectApprovalSystem.Models.ResearchArea>)ViewBag.AllAreas)
                        {
                            var isSelected = Model.Expertise.Any(e => e.ResearchAreaId == area.Id);
                            <div class="col-md-6">
                                <label class="expertise-card @(isSelected ? "active" : "")" for="area_@area.Id">
                                    <div class="expertise-header">
                                        <div class="form-check m-0">
                                            <input class="form-check-input" type="checkbox" name="researchAreaIds" value="@area.Id" id="area_@area.Id" @(isSelected ? "checked" : "")>
                                        </div>
                                        <div class="fw-bold fs-5 ms-3 name">@area.Name</div>
                                    </div>
                                    <p class="text-muted small mt-3 mb-0">@area.Description</p>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-3 justify-content-center pt-3 border-top mt-5">
                        <a asp-action="Dashboard" class="btn btn-outline-dark btn-lg px-5 rounded-pill">Cancel</a>
                        <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm fw-bold">
                            <i class="bi bi-save2-fill me-2"></i>Update Preferences
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .expertise-card {
        display: block;
        padding: 1.5rem;
        border: 2px solid #eaecf0;
        border-radius: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        background: #fff;
        height: 100%;
    }
    .expertise-card:hover {
        border-color: #3f51b5;
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }
    .expertise-card.active {
        border-color: #3f51b5;
        background-color: rgba(63, 81, 181, 0.02);
    }
    .expertise-header {
        display: flex;
        align-items: center;
    }
    .expertise-card.active .name { color: #3f51b5; }
    .tracking-widest { letter-spacing: 0.15em; }
</style>
